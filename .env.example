# Public URL used for local redirects and absolute links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public Supabase values. Replace the key with the value printed by `pnpm db:status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key
