# Public URL used for local redirects and absolute links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public Supabase values. Replace the key with the value printed by `pnpm db:status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key
GOOGLE_AUTH_ENABLED=false

# Server-only key used for public Google Books metadata requests.
GOOGLE_BOOKS_API_KEY=replace-with-google-books-api-key

# Server identification requested by Open Library. Include a real contact.
OPEN_LIBRARY_USER_AGENT=Procrastibook/0.1 (contact: replace-with-email)
